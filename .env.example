# Local conectado a PostgreSQL. Puedes usar Railway y ejecutar: railway variables --service Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agenda_profesional?schema=public"

# En local, Next.js usa /api y next.config.mjs redirige a Express en API_PROXY_URL.
# En Railway con un solo servicio, /api queda en el mismo dominio.
NEXT_PUBLIC_API_URL="/api"

# Express usa este puerto en local. Railway inyecta PORT automáticamente.
PORT=4000

# Opcional: restringe el origen CORS en producción, por ejemplo https://tu-app.up.railway.app
CORS_ORIGIN=""
API_PROXY_URL="http://localhost:4000"
